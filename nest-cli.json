{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "apps/api/src",
  "monorepo": true,
  "root": "apps/api",
  "compilerOptions": {
    "webpack": false,
    "tsConfigPath": "apps/api/tsconfig.app.json"
  },
  "projects": {
    "api": {
      "type": "application",
      "root": "apps/api",
      "entryFile": "main",
      "sourceRoot": "apps/api/src",
      "compilerOptions": {
        "tsConfigPath": "apps/api/tsconfig.app.json"
      }
    },
    "worker-ingest": {
      "type": "application",
      "root": "apps/worker-ingest",
      "entryFile": "main",
      "sourceRoot": "apps/worker-ingest/src",
      "compilerOptions": {
        "tsConfigPath": "apps/worker-ingest/tsconfig.app.json"
      }
    },
    "worker-decode": {
      "type": "application",
      "root": "apps/worker-decode",
      "entryFile": "main",
      "sourceRoot": "apps/worker-decode/src",
      "compilerOptions": {
        "tsConfigPath": "apps/worker-decode/tsconfig.app.json"
      }
    },
    "worker-backfill": {
      "type": "application",
      "root": "apps/worker-backfill",
      "entryFile": "main",
      "sourceRoot": "apps/worker-backfill/src",
      "compilerOptions": {
        "tsConfigPath": "apps/worker-backfill/tsconfig.app.json"
      }
    },
    "chain-provider": {
      "type": "library",
      "root": "libs/chain-provider",
      "entryFile": "index",
      "sourceRoot": "libs/chain-provider/src",
      "compilerOptions": {
        "tsConfigPath": "libs/chain-provider/tsconfig.lib.json"
      }
    },
    "db": {
      "type": "library",
      "root": "libs/db",
      "entryFile": "index",
      "sourceRoot": "libs/db/src",
      "compilerOptions": {
        "tsConfigPath": "libs/db/tsconfig.lib.json"
      }
    },
    "queue": {
      "type": "library",
      "root": "libs/queue",
      "entryFile": "index",
      "sourceRoot": "libs/queue/src",
      "compilerOptions": {
        "tsConfigPath": "libs/queue/tsconfig.lib.json"
      }
    },
    "abi": {
      "type": "library",
      "root": "libs/abi",
      "entryFile": "index",
      "sourceRoot": "libs/abi/src",
      "compilerOptions": {
        "tsConfigPath": "libs/abi/tsconfig.lib.json"
      }
    },
    "common": {
      "type": "library",
      "root": "libs/common",
      "entryFile": "index",
      "sourceRoot": "libs/common/src",
      "compilerOptions": {
        "tsConfigPath": "libs/common/tsconfig.lib.json"
      }
    }
  }
}
