{
  "name": "blockchain-indexer",
  "version": "0.0.1",
  "description": "Blockchain indexer and explorer platform",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "build:api": "nest build api",
    "build:worker-ingest": "nest build worker-ingest",
    "build:worker-decode": "nest build worker-decode",
    "build:worker-backfill": "nest build worker-backfill",
    "start:dev": "nest start --watch",
    "start:dev:api": "nest start api --watch",
    "start:dev:worker-ingest": "nest start worker-ingest --watch",
    "start:dev:worker-decode": "nest start worker-decode --watch",
    "start:dev:worker-backfill": "nest start worker-backfill --watch",
    "start:prod:api": "node dist/apps/api/main",
    "start:prod:worker-ingest": "node dist/apps/worker-ingest/main",
    "start:prod:worker-decode": "node dist/apps/worker-decode/main",
    "start:prod:worker-backfill": "node dist/apps/worker-backfill/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "typeorm": "ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js",
    "migration:generate": "yarn typeorm migration:generate -d libs/db/src/data-source.ts",
    "migration:run": "yarn typeorm migration:run -d libs/db/src/data-source.ts",
    "migration:revert": "yarn typeorm migration:revert -d libs/db/src/data-source.ts"
  },
  "dependencies": {
    "@nestjs/bull": "^10.1.1",
    "@nestjs/common": "^10.3.0",
    "@nestjs/config": "^3.1.1",
    "@nestjs/core": "^10.3.0",
    "@nestjs/platform-express": "^10.3.0",
    "@nestjs/schedule": "^4.0.0",
    "@nestjs/typeorm": "^10.0.1",
    "bull": "^4.12.0",
    "ethers": "^6.11.0",
    "pg": "^8.11.3",
    "redis": "^4.6.12",
    "reflect-metadata": "^0.2.1",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.19"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.3.0",
    "@nestjs/schematics": "^10.1.0",
    "@nestjs/testing": "^10.3.0",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.11",
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^6.18.0",
    "@typescript-eslint/parser": "^6.18.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.3.3"
  },
  "jest": {
    "moduleFileExtensions": ["js", "json", "ts"],
    "rootDir": ".",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": ["**/*.(t|j)s"],
    "coverageDirectory": "./coverage",
    "testEnvironment": "node",
    "roots": ["<rootDir>/apps/", "<rootDir>/libs/"],
    "moduleNameMapper": {
      "^@app/chain-provider(|/.*)$": "<rootDir>/libs/chain-provider/src/$1",
      "^@app/db(|/.*)$": "<rootDir>/libs/db/src/$1",
      "^@app/queue(|/.*)$": "<rootDir>/libs/queue/src/$1",
      "^@app/abi(|/.*)$": "<rootDir>/libs/abi/src/$1",
      "^@app/common(|/.*)$": "<rootDir>/libs/common/src/$1"
    }
  }
}
