NODE_ENV=development
PORT=3000

# Database
DB_HOST=postgres
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=blockchain_indexer

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# Chain configuration
CHAIN_ID=1
CHAIN_NAME=ethereum
CHAIN_PROVIDER_TYPE=rpc
CHAIN_RPC_URL=https://your-rpc-url
CHAIN_WS_URL=wss://your-ws-url

# Ingestion settings
INGEST_CONFIRMATIONS=6
INGEST_BATCH_SIZE=50
INGEST_POLL_INTERVAL_MS=5000

# Backfill settings
BACKFILL_BATCH_SIZE=250
START_BLOCK=0
